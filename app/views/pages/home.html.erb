<div class="antialiased text-slate-900 bg-white selection:bg-green-100 selection:text-green-900">

  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-green-900/80 via-green-900/60 to-green-900/90 z-10"></div>
      <video autoplay muted loop playsinline class="w-full h-full object-cover scale-105 animate-slow-zoom">
        <source src="<%= asset_path('kayabaVd.mp4') %>" type="video/mp4">
      </video>
    </div>

    <div class="relative z-20 max-w-5xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/20 border border-green-400/30 backdrop-blur-md text-green-300 text-xs font-bold uppercase tracking-[0.2em] mb-8 animate-fade-in-up">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        Established 1992
      </div>
      
      <h1 class="text-2xl md:text-3xl lg:text-4xl font-black text-white leading-tight mb-8">
        He gives hope to the poor <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-300 to-emerald-500">and silences the wicked</span>
      </h1>
      
      <p class="text-lg md:text-2xl text-green-50/80 max-w-2xl mx-auto mb-12 leading-relaxed font-light">
        Empowering communities, uplifting lives, and nurturing growth through faith, education, and service.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <%= link_to "Get Involved", "#mission", class: "group relative px-10 py-5 bg-green-600 text-white rounded-full text-lg font-bold overflow-hidden transition-all hover:ring-4 hover:ring-green-500/30" %>
        <%= link_to "Our Story", "#about", class: "px-10 py-5 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-full text-lg font-bold hover:bg-white/20 transition-all" %>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <div class="w-1 h-12 rounded-full bg-gradient-to-b from-green-400 to-transparent opacity-50"></div>
    </div>
  </section>

  <section id="about" class="py-24 lg:py-40 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="relative z-10 rounded-[2rem] overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500">
            <%= image_tag "us3.jpg", alt: "Community work", class: "w-full aspect-[4/3] object-cover" %>
          </div>
          <div class="absolute -inset-4 bg-green-100 -rotate-2 rounded-[2rem] -z-10"></div>
          <div class="absolute -bottom-10 -right-10 bg-green-600 text-white p-10 rounded-3xl hidden md:block">
            <span class="block text-5xl font-black italic">20+</span>
            <span class="text-sm uppercase tracking-widest font-bold opacity-80">Years of Faith</span>
          </div>
        </div>

        <div class="lg:pl-12">
          <h2 class="text-4xl lg:text-6xl font-bold text-green-950 mb-8 leading-tight">Uplifting Souls <br/>Since Day One.</h2>
          <div class="space-y-6 text-xl text-slate-600 leading-relaxed">
            <p>Our ministry isn't just an organization; it's a living, breathing movement dedicated to sustainable change.</p>
            <p class="border-l-4 border-green-600 pl-6 italic text-green-900 font-medium">
              "We focus on creating sustainable impact and nurturing growth at every level."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-green-950 text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid md:grid-cols-2 gap-8">
        <div id="mission" class="p-12 rounded-[3rem] bg-gradient-to-br from-green-900 to-green-950 border border-green-800/50 hover:border-green-500/50 transition-colors">
          <div class="w-16 h-16 bg-green-500/20 rounded-2xl flex items-center justify-center mb-8">
            <span class="text-3xl text-green-400">🎯</span>
          </div>
          <h2 class="text-3xl font-bold mb-6">Our Mission</h2>
          <p class="text-green-100/70 text-lg leading-relaxed">
            To empower communities and individuals to experience hope, dignity, and growth through faith-driven initiatives and compassionate service.
          </p>
        </div>

        <div id="vision" class="p-12 rounded-[3rem] bg-gradient-to-br from-green-900 to-green-950 border border-green-800/50 hover:border-green-500/50 transition-colors">
          <div class="w-16 h-16 bg-green-500/20 rounded-2xl flex items-center justify-center mb-8">
            <span class="text-3xl text-green-400">👁️</span>
            <span class="text-3xl text-green-400">👁️</span>
          </div>
          <h2 class="text-3xl font-bold mb-6">Our Vision</h2>
          <p class="text-green-100/70 text-lg leading-relaxed">
            A world where hope is accessible to every individual, communities thrive, and lives are transformed through service and faith.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="history" class="py-24 lg:py-32 bg-green-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <div class="inline-block px-6 py-2 bg-white rounded-full text-green-600 font-bold text-sm mb-6 shadow-sm">OUR LEGACY</div>
      <h2 class="text-4xl lg:text-5xl font-bold text-green-950 mb-16">Growing Together Since 1992</h2>
      
      <div class="relative">
        <span class="text-[12rem] md:text-[20rem] font-black text-green-100 leading-none select-none">1992</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <p class="max-w-2xl text-xl lg:text-2xl text-green-800 font-medium">
            Since our founding, the ministry has grown to reach thousands of lives, running programs in education and health with transparency and faith at the core.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="values" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
        <div>
          <h2 class="text-4xl lg:text-6xl font-bold text-green-950">Core Values</h2>
          <p class="text-green-600 font-bold mt-4 tracking-widest uppercase">The heart of everything we do</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-green-100 rounded-[3rem] overflow-hidden shadow-xl">
        <div class="p-12 bg-white border-b md:border-b-0 md:border-r border-green-100 hover:bg-green-50 transition-colors group">
          <span class="text-4xl block mb-6 filter grayscale group-hover:grayscale-0 transition-all">❤️</span>
          <h3 class="text-2xl font-bold text-green-950 mb-4">Compassion</h3>
          <p class="text-slate-600 leading-relaxed">We serve with kindness, empathy, and a genuine desire to make a difference.</p>
        </div>

        <div class="p-12 bg-white border-b md:border-b-0 md:border-r border-green-100 hover:bg-green-50 transition-colors group">
          <span class="text-4xl block mb-6 filter grayscale group-hover:grayscale-0 transition-all">📖</span>
          <h3 class="text-2xl font-bold text-green-950 mb-4">Integrity</h3>
          <p class="text-slate-600 leading-relaxed">Acting with honesty and upholding strong ethical principles in all we do.</p>
        </div>

        <div class="p-12 bg-white hover:bg-green-50 transition-colors group">
          <span class="text-4xl block mb-6 filter grayscale group-hover:grayscale-0 transition-all">🌱</span>
          <h3 class="text-2xl font-bold text-green-950 mb-4">Growth</h3>
          <p class="text-slate-600 leading-relaxed">Empowering individuals and communities to thrive sustainably.</p>
        </div>
      </div>
    </div>
  </section>

</div>

<style>
  @keyframes slow-zoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.15); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 20s infinite alternate ease-in-out;
  }
</style>